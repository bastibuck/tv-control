[Unit]
Description=tv-control server
After=network.target

[Service]
Type=simple
User=bastibuck
WorkingDirectory=/home/bastibuck/dev/tv-control
ExecStart=/home/bastibuck/.volta/bin/node apps/server/dist/index.js
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
